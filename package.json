{
  "name": "@bounded-systems/git",
  "version": "0.1.0",
  "description": "Git CLI wrapper with policy enforcement and stale-lock recovery",
  "bounded": {
    "tagline": "Git CLI wrapper with policy enforcement and stale-lock recovery",
    "kind": "door"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/git.git"
  },
  "homepage": "https://github.com/bounded-systems/git#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/git/issues"
  },
  "keywords": [
    "git",
    "cli-wrapper",
    "policy",
    "stale-lock",
    "capability",
    "seam"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/env": "npm:@jsr/bounded-systems__env",
    "@bounded-systems/fs": "npm:@jsr/bounded-systems__fs",
    "@bounded-systems/policy": "npm:@jsr/bounded-systems__policy",
    "@bounded-systems/proc": "npm:@jsr/bounded-systems__proc"
  }
}
